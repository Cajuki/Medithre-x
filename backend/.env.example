# =============================================================================
# Medithrex Backend — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Resend API email delivery
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
EMAIL_FROM=MedithreX <medithrexmedicalsolutions@gmail.com>

# ── Frontend URL (used for CORS) ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# =============================================================================
# DATABASE — Choose ONE of the two options below
# =============================================================================

# ── OPTION A: Local PostgreSQL (development) ──────────────────────────────────
# Leave DATABASE_URL blank and fill in the individual variables below
DATABASE_URL=

PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=medithrex
PG_USER=postgres
PG_PASSWORD=your_local_postgres_password

# ── OPTION B: Neon (production / cloud) ──────────────────────────────────────
# Paste your Neon connection string here — overrides all PG_* variables above
# Get it from: https://console.neon.tech → your project → Connection Details
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require
#
# DATABASE_URL=postgresql://neondb_owner:npg_9HMBCikzcq8w@ep-sparkling-surf-absbdv2x-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# =============================================================================
# IMAGE UPLOADS — Cloudinary (for product photo uploads from admin panel)
# Get credentials from: https://cloudinary.com/console
# =============================================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
