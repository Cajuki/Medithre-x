# =============================================================================
# Medithrex Backend — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars

# ── Frontend URL (used for CORS) ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# =============================================================================
# DATABASE — Choose ONE of the two options below
# =============================================================================

# ── OPTION A: Local PostgreSQL (development) ──────────────────────────────────
# Leave DATABASE_URL blank and fill in the individual variables below
DATABASE_URL=

PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=medithrex
PG_USER=postgres
PG_PASSWORD=your_local_postgres_password

# ── OPTION B: Neon (production / cloud) ──────────────────────────────────────
# Paste your Neon connection string here — overrides all PG_* variables above
# Get it from: https://console.neon.tech → your project → Connection Details
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
#
# DATABASE_URL=postgresql://medithrex_owner:xxxx@ep-xxx.us-east-2.aws.neon.tech/medithrex?sslmode=require

# =============================================================================
# IMAGE UPLOADS — Cloudinary (for product photo uploads from admin panel)
# Free tier: 25GB storage, 25GB bandwidth/month — plenty for product images
# Sign up at: https://cloudinary.com
# =============================================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=medithrex_products
CLOUDINARY_CATEGORY_FOLDER=medithrex_categories
