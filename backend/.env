# ── Server ────────────────────────────────────────
# Cloud Run injects PORT at runtime. In local dev without PORT set, defaults to 8080

# ── PostgreSQL ────────────────────────
# For local development (comment out DATABASE_URL)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=medithrex
PG_USER=postgres
PG_PASSWORD=your_password_here
PG_SSL=false

# For Neon production (uncomment when deploying)
DATABASE_URL=postgresql://neondb_owner:npg_9HMBCikzcq8w@ep-sparkling-surf-absbdv2x-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ── Auth ─────────────────────────────
JWT_SECRET=medithrex_super_secret_key_2024

# ── Email (Nodemailer SMTP) ───────────────────────────────────────────────────
# Configure your email provider (e.g., Gmail, SendGrid, Mailgun)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Medithrex <noreply@medithrex.com>

# ── Frontend URL (for production CORS) ───────────
