# ─────────────────────────────────────────────────────────────────────────────
# Frontend Environment Variables — Production
# Copy this to .env.production and fill in your Cloud Run URL
# ─────────────────────────────────────────────────────────────────────────────

# Your Cloud Run backend URL (no trailing slash)
# Get this after deploying: gcloud run services describe medithrex-backend --region=REGION --format="value(status.url)"
VITE_API_URL=https://medithrex-backend-xxxxxxxxxx-uc.a.run.app

VITE_APP_NAME=Medithrex
