{
  "routes": [
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/favicon.svg", "dest": "/favicon.svg" }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://medithre-x-180462915671.europe-west1.run.app/sitemap.xml"
    },
    {
      "source": "/api/:path*",
      "destination": "https://medithre-x-180462915671.europe-west1.run.app/api/:path*"
    },
    {
      "source": "/*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ]
}